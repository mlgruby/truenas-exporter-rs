{
  "hooks": {
    "SessionStart": [{
      "hooks": [{
        "type": "command",
        "command": "bash .claude/hooks/session-start.sh 2>/dev/null || true"
      }]
    }]
  },
  "permissions": {
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore .:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(gh release create:*)",
      "Bash(cat ~/.aws/*)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cat *credentials*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(cat .env)",
      "Read(/Users/*/.aws/*)",
      "Read(/Users/*/.ssh/*)",
      "Read(/Users/*/.*credentials*)",
      "Read(/Users/*/*.pem)",
      "Read(/Users/*/*.key)"
    ],
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo audit:*)",
      "Bash(cargo update:*)",
      "Bash(cargo run:*)",
      "Bash(make:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(tail:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git push origin:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",
      "Bash(docker build:*)",
      "Bash(docker run:*)",
      "Bash(docker stop:*)",
      "Bash(docker rm:*)",
      "Bash(docker logs:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker stats:*)",
      "Read(/private/tmp/**)"
    ]
  }
}
